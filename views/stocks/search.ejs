<%- include('../partials/header', { title: 'Search Stocks' }) %>

<div class="container">
  <div class="page-title">Search NSE Stocks</div>

  <div class="card" style="max-width:500px">
    <form method="POST" action="/stocks/search">
      <div class="form-group">
        <label>Stock Symbol</label>
        <input type="text" name="symbol" placeholder="e.g. RELIANCE, TCS, INFY" required />
      </div>
      <button class="btn btn-primary" type="submit">Search</button>
    </form>
  </div>

  <% if (error) { %>
    <div class="alert alert-error" style="max-width:500px"><%= error %></div>
  <% } %>

  <% if (result) { %>
    <div class="card" style="max-width:500px">
      <h3 style="color:#1B3A6B; margin-bottom:8px"><%= result.companyName %></h3>
      <p style="color:#888; margin-bottom:16px">NSE: <%= result.symbol %></p>
      <div class="summary-row">
        <div class="summary-card">
          <p>Current Price</p>
          <h3>₹<%= result.price.toFixed(2) %></h3>
        </div>
      </div>
      <a class="btn btn-success" href="/stocks/buy?symbol=<%= result.symbol %>&price=<%= result.price %>">
        Buy <%= result.symbol %>
      </a>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>