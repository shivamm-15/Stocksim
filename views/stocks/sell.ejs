<%- include('../partials/header', { title: 'Sell ' + symbol }) %>

<div class="container">
  <div class="page-title">Sell <%= symbol %></div>

  <div class="form-card">
    <div class="summary-row" style="margin-bottom:20px">
      <div class="summary-card">
        <p>Current Price</p>
        <h3>₹<%= currentPrice.toFixed(2) %></h3>
      </div>
      <div class="summary-card">
        <p>Shares Owned</p>
        <h3><%= holding.quantity %></h3>
      </div>
      <div class="summary-card">
        <p>Avg Buy Price</p>
        <h3>₹<%= Number(holding.avg_buy_price).toFixed(2) %></h3>
      </div>
      <% var pnl = ((currentPrice - holding.avg_buy_price) * holding.quantity).toFixed(2); %>
      <div class="summary-card <%= pnl >= 0 ? 'profit' : 'loss' %>">
        <p>Unrealized P&L</p>
        <h3><%= pnl >= 0 ? '+' : '' %>₹<%= pnl %></h3>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/stocks/sell">
      <input type="hidden" name="symbol" value="<%= symbol %>" />
      <input type="hidden" name="price" value="<%= currentPrice %>" />
      <input type="hidden" id="stockPrice" value="<%= currentPrice %>" />

      <div class="form-group">
        <label>Quantity to sell (max <%= holding.quantity %>)</label>
        <input type="number" name="quantity" id="qtyInput" min="1" max="<%= holding.quantity %>" required/>
      </div>

      <div class="summary-card" style="margin-bottom:20px">
        <p>You will receive</p>
        <h3>₹<span id="earnings">0.00</span></h3>
      </div>

      <button class="btn btn-danger" type="submit">Confirm Sell</button>
      <a class="btn btn-primary" style="margin-left:10px" href="/portfolio">Cancel</a>
    </form>
  </div>
</div>

<script>
  document.getElementById('qtyInput').addEventListener('input', function() {
    var qty = parseInt(this.value) || 0;
    var price = parseFloat(document.getElementById('stockPrice').value);
    document.getElementById('earnings').textContent = (qty * price).toFixed(2);
  });
</script>

<%- include('../partials/footer') %>